---
import Pill from './Pill.astro'
import Mail from '@/assets/Mail.astro'
import GitHub from '@/assets/GitHub.astro'
import LinkedIn from '@/assets/LinkedIn.astro';
---

<footer class="flex flex-col w-full max-w-[900px] mx-auto mb-6 md:mb-10 p-4 gap-6">
  <div class="w-full mx-auto flex justify-between items-center">
    <div class="flex flex-col justify-center">
      <strong class="text-xl font-semibold text-blue-600/90 dark:text-blue-400/90">Omar Mancilla</strong>
      <span class="text-sm text-slate-600 dark:text-white/60">Desarrollador FullStack</span>
    </div>
    <div class="flex items-center gap-2">
      <Pill href="https://github.com/omancillav" class="!p-2.5">
        <GitHub class="size-4 md:size-5" />
      </Pill>
      <Pill href="https://www.linkedin.com/in/omancilla" class="!p-2.5">
        <LinkedIn class="size-4 md:size-5" />
      </Pill>
      <Pill href="mailto:omancilla.dev@gmail.com" class="!p-2.5">
        <Mail class="size-4 md:size-5" />
      </Pill>
    </div>
  </div>
  <span class="flex w-full bg-sky-200 dark:bg-blue-900 h-[1px]"></span>
  <div class="flex flex-col text-center">
    <span class="text-sm text-slate-500 dark:text-white/50"> © 2026 Casi todos los derechos reservados. </span>
  </div>
</footer>
