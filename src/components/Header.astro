---
import ThemeToggle from '@/components/ThemeToggle.astro'
---

<header class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-auto">
  <nav
    class="flex flex-row items-center gap-2 md:gap-5 px-3 md:px-5 py-1.5 rounded-full
    bg-white/75 backdrop-blur-md border border-slate-200/80 shadow-lg shadow-slate-900/5
