---
import ThemeToggle from '@/components/ThemeToggle.astro'
---

<header class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-auto">
  <nav
    class="isolate flex flex-row items-center gap-3 overflow-hidden px-4 pr-3 py-2 rounded-full
    max-[360px]:gap-2 max-[360px]:px-3 max-[360px]:pr-2 max-[360px]:py-1.5 md:gap-5 md:px-5 md:pr-5 md:py-1 md:leading-none
    bg-white/55 backdrop-blur-xl backdrop-saturate-200 border border-white/70 shadow-[0_10px_35px_rgba(15,23,42,0.16),inset_0_1px_0_rgba(255,255,255,0.82)]
    text-[14px] max-[360px]:text-[13px] text-slate-700 hover:text-slate-950
    dark:bg-white/[0.08] dark:backdrop-saturate-100 dark:border-white/15 dark:shadow-[0_10px_35px_rgba(0,0,0,0.22),inset_0_1px_0_rgba(255,255,255,0.18)] dark:text-white/90 dark:hover:text-white"
  >
    <a href="#inicio" class="transition-colors duration-200 font-medium whitespace-nowrap"> Inicio </a>
    <a href="#experience" class="transition-colors duration-200 font-medium whitespace-nowrap"> Experiencia </a>
    <a href="#projects" class="transition-colors duration-200 font-medium whitespace-nowrap"> Proyectos </a>
    <a href="#stack" class="transition-colors duration-200 font-medium whitespace-nowrap"> Tecnologías </a>
    <!-- <a href="#about" class="transition-colors duration-200 font-medium whitespace-nowrap"> Sobre mí </a> -->
    <ThemeToggle />
  </nav>
</header>
