    <a href="#experience" class="transition-colors duration-200 font-medium whitespace-nowrap"> Experiencia </a>
    <a href="#projects" class="transition-colors duration-200 font-medium whitespace-nowrap"> Proyectos </a>
    <a href="#stack" class="transition-colors duration-200 font-medium whitespace-nowrap"> Tecnologías </a>
