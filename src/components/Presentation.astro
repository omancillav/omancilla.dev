---
import { Image } from 'astro:assets'
import AvatarDark from '@/assets/img/avatar.webp'
import AvatarLight from '@/assets/img/avatar-light.webp'
import Badge from '@/components/Badge.astro'
import GitHubIcon from '@/assets/GitHub.astro'
import LinkedInIcon from '@/assets/LinkedIn.astro'
import MailIcon from '@/assets/Mail.astro'
import ArrowDownIcon from '@/assets/ArrowDown.astro'
import SocialPill from '@/components/Pill.astro';
---

<div>
  <div class="flex flex-col md:flex-row items-start md:items-center gap-6 mb-6 md:gap-8">
    <div class="flex items-center gap-4 md:gap-0">
      <div class="relative size-26 md:size-36 my-auto">
        <Image
          src={AvatarLight}
          alt="Avatar omancilla"
          class="rounded-full size-full absolute inset-0 transition-opacity duration-500 ease-in-out opacity-100 dark:opacity-0"
          decoding="async"
          loading="eager"
          width={500}
          height={500}
          format="webp"
        />
        <Image
          src={AvatarDark}
          alt="Avatar omancilla"
          class="rounded-full size-full absolute inset-0 transition-opacity duration-500 ease-in-out opacity-0 dark:opacity-100"
          decoding="async"
          loading="eager"
          width={500}
          height={500}
          format="webp"
        />
      </div>
      <div class="md:hidden">
        <Badge>Desarrollador FullStack</Badge>
      </div>
    </div>
    <div class="flex flex-col gap-4">
      <div class="hidden md:block">
        <Badge>Desarrollador FullStack</Badge>
      </div>
      <h1 class="text-slate-950 dark:text-white text-3xl md:text-5xl font-bold gap-6 md:gap-4">
        Hey, soy <span class="text-sky-600 dark:text-sky-400/85">Omar Mancilla</span>
      </h1>
    </div>
  </div>
  <h2 class="text-xl text-slate-700 text-pretty dark:text-white dark:opacity-80">
    <span class="text-yellow-500 dark:text-yellow-200">+1 Año de experiencia en desarrollo web. </span>Estudiante de
    Ingeniería en Desarrollo de Software.
    <span class="text-emerald-600 dark:text-green-300"> De México 🇲🇽.</span>
    <span class="opacity-85">
      Enfocado en desarrollar soluciones digitales innovadoras que mejoren la experiencia de usuario.
    </span>
  </h2>
  <nav class="flex gap-x-2 gap-y-3 md:gap-x-4 md:gap-y-4 mt-8 flex-wrap">
    <SocialPill href="https://github.com/omancillav">
      <GitHubIcon class="size-4 md:size-5" />
      GitHub
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/omancilla">
      <LinkedInIcon class="size-4 md:size-5" />
      LinkedIn
    </SocialPill>
    <SocialPill href="mailto:omancilla.dev@gmail.com">
      <MailIcon class="size-4 md:size-5" />
      Contacto
    </SocialPill>
  </nav>
  <a
    href="#experience"
    aria-label="Ir a experiencia"
    class="absolute bottom-1 left-1/2 -translate-x-1/2 rounded-full p-2 text-slate-600 transition hover:text-slate-950 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-sky-500 motion-safe:animate-bounce dark:text-white/75 dark:hover:text-white"
  >
    <ArrowDownIcon class="size-7 md:size-8" aria-hidden="true" />
  </a>
</div>
