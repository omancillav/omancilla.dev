---
const { href, class: className } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={`rounded-full border border-white/45 flex justify-center items-center gap-x-2 py-2 px-4 text-sm md:text-base
  bg-white/28 text-slate-700 shadow-[0_10px_30px_rgba(15,23,42,0.08)] backdrop-blur-md hover:scale-105 hover:bg-white/36 transition w-fit
  dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10 ${className}`}
>
  <slot />
</a>
